*.db
*.db-shm
*.db-wal
*.log

# The user's local data directory
.conan/

# ── Secrets and environment ───────────────────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key

# ── Build outputs ─────────────────────────────────────────────────────────────
dist/
*.tar.gz
*.zip

# ── Test artifacts ────────────────────────────────────────────────────────────
/tmp/
conan_history_*.db
